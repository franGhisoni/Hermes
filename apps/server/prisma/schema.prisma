generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Source {
  id              String   @id @default(uuid())
  name            String
  url             String
  active          Boolean  @default(true)
  scraperConfig   Json     // Stores selectors, wait times, etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  articles        Article[]
  routeRules      RouteRule[]
}

model SystemSetting {
  key   String @id
  value String
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Target {
  id        String     @id @default(uuid())
  name      String     @unique
  email     String
  workflows Workflow[] // Implicit M2M
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Workflow {
  id              String   @id @default(uuid())
  name            String
  section         String?  // Optional: only publish articles from this section
  sources         String[] // Optional: array of source names to constrain extraction
  minScore        Int?     // Optional: minimum interest score required
  targetCategory  String?  // Custom category name for the destination (e.g. WordPress)
  cron            String
  isActive        Boolean  @default(true)
  maxArticles     Int      @default(3) // Maximum articles to publish per cycle
  // When true and the article pool is smaller than the number of targets, the
  // workflow refills the missing destinations by reusing articles with a fresh
  // AI rewrite and a fresh image search so each target still receives unique
  // content. When false, missing destinations are skipped and logged.
  allowRepublish  Boolean  @default(false)
  // Round-robin cursor: index into the alphabetically-sorted target list where
  // the next execution should start dispatching. Lets multi-run cron schedules
  // eventually cover every destination when the article pool is smaller than
  // the workflow's target count.
  nextTargetIndex Int      @default(0)
  targets         Target[] // Implicit many-to-many
  runs            WorkflowRun[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WorkflowRun {
  id               String   @id @default(uuid())
  workflowId       String
  workflow         Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  startedAt        DateTime @default(now())
  durationMs       Int?
  status           WorkflowRunStatus
  targetsTotal     Int      @default(0)
  targetsCovered   Int      @default(0)  // sends that succeeded
  targetsSkipped   Int      @default(0)  // targets with no article (refill off, pool empty)
  articlesUnique   Int      @default(0)  // distinct articles dispatched
  articlesRefilled Int      @default(0)  // refill dispatches (republished with fresh rewrite/image)
  summary          String
  errorMessage     String?

  @@index([workflowId, startedAt])
}

enum WorkflowRunStatus {
  SUCCESS
  PARTIAL
  EMPTY
  ERROR
}

model ScrapeSchedule {
  id        String   @id @default(uuid())
  source    String   // "Clarin", "LaNacion", etc.
  cron      String   // Cron expression
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id        String   @id @default(uuid())
  name      String   
  path      String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([name, path])
}

enum UserRole {
  ADMIN
  EDITOR
}

model Article {
  id              String   @id @default(uuid())
  sourceId        String
  source          Source   @relation(fields: [sourceId], references: [id])
  
  section         String?  // e.g. "Politica", "Economia"
  originalTitle   String
  originalContent String
  originalUrl     String   @unique
  originalImageUrl String?
  publishedAt     DateTime // When it was published on the source
  
  // Intelligence
  embedding       Unsupported("vector(1536)")?
  interestScore   Int?     // 1-10
  analysisData    Json?    // Stores raw AI analysis stats
  
  // Rewrite
  rewrittenTitle   String?
  rewrittenContent String?
  
  featureImageUrl  String?  // The final image used for publication (Original, Found, or Generated)
  imageCandidates  String[] // Array of candidate image URLs (from search or generation)
  imageScores      Json?    // Map of { "url": score }
  
  status          ArticleStatus @default(PENDING)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ArticleStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

model GeneratedImage {
  id        String   @id @default(uuid())
  data      Bytes
  mimeType  String   @default("image/png")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model PromptConfig {
  id          String      @id @default(uuid())
  name        String
  template    String      // The prompt text with {{placeholders}}
  type        PromptType
  
  routeRules  RouteRule[]
}

enum PromptType {
  REWRITE
  INTEREST
  STYLE
  IMAGE_SELECT
}

model PublicationTarget {
  id          String   @id @default(uuid())
  name        String
  type        TargetType
  config      Json     // { email: "blog@wordpress.com", etc }
  active      Boolean  @default(true)
  
  routeRules  RouteRule[]
}

enum TargetType {
  WORDPRESS_EMAIL
  TWITTER
  CUSTOM_WEBHOOK
}

// Logic: If Source A, Use Prompt B, Send to Target C
model RouteRule {
  id          String   @id @default(uuid())
  
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])
  
  promptId    String
  prompt      PromptConfig @relation(fields: [promptId], references: [id])
  
  targetId    String
  target      PublicationTarget @relation(fields: [targetId], references: [id])
  
  active      Boolean @default(true)
}
